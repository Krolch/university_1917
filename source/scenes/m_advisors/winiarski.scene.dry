@trans_
title: Transportation Policy
subtitle: Winiarski is the Transport Minister in the Provisional Government.
choose-if: advisor_action_timer = 0 and transport_minister = "Winiarski"
unavailable-subtitle: [? if advisor_action_timer > 0 : [+ advisor_action_timer +] weeks before next advisor action. ?] [? if transport_minister != "Winiarski" : Winiarski is not the Transport Minister. ?]
on-arrival: advisor_action_timer = 4; transport_policy_timer -= 4; last_advisor_action = 1
go-to: transport_policy

